# SGLang Engine Server Environment Variables
# Copy to .env and adjust as needed

# Model path
SGL_MODEL_PATH=/home/fnl/models/Qwen3-32B

# Engine server settings
SGL_ENGINE_HOST=0.0.0.0
SGL_ENGINE_PORT=30001
SGL_MEM_FRACTION_STATIC=0.80

# Generation defaults
SGL_DEFAULT_MAX_NEW_TOKENS=256
SGL_DEFAULT_TEMPERATURE=0.7
SGL_DEFAULT_TOP_P=0.95

# Logging
SGL_ENGINE_LOG_LEVEL=INFO

# Optional: HuggingFace mirror (if needed)
# HF_ENDPOINT=https://hf-mirror.com

# Optional: Proxy settings (if behind proxy)
# http_proxy=http://127.0.0.1:8888
# https_proxy=http://127.0.0.1:8888
